LAYOUT (WINDOWSTYLE="main2",TEXT="Retrieval Augmented Generation (RAG)")

HBOX (SPLITTER)

VBOX

GRID
{
SQL DB server/source:[dbs                    ][src                         ]
AI provider/model:   [pro            ][mod             ]
Vector dim:          [dim    ]               Max cosine similarity: [csm   ]
[b1                    ][b2                     ][b3                       ]
}
END

SCROLLGRID (WANTFIXEDPAGESIZE=NO,STYLE="style1")
{
-----------------------------------------------------------------------------------
[id   ][sn                      |ca            ] Vector Embedding
[de                                            ][ve                               ]
[                                              ][                                 ]
[                                              ][                                 ]
}
END
END

FOLDER

PAGE p1 (TEXT="System Prompt")
GRID
{
System prompt for LLM:
[smg                                                    ]
[                                                       ]
[                                                       ]
[                                                       ]
[                                                       ]
[                                                       ]
}
END
END

PAGE p2 (TEXT="2-step query")
GRID
{
Search in local SQL database:
[qry                                                    ]
[csv                                                    ]
[qrv                                                    ]
[                                                       ]
[                                                       ]
[fma                                                    ]
Context message for LLM:
[amg                                                    ]
[                                                       ]
[                                                       ]
[                                                       ]
[                                                       ]
[                                                       ]
[                                                       ]
[                                                       ]
User question for LLM:
[uq1                                                    ]
[q1                                                     ]
Response:
[rs1                                                    ]
[                                                       ]
[                                                       ]
[                                                       ]
}
END
END

PAGE p3 (TEXT="Direct answer")
GRID
{
User question for LLM:
[uq2                                                    ]
[q2                                                     ]
Response:
[rs2                                                    ]
[                                                       ]
[                                                       ]
[                                                       ]
}
END
END

END
END

ATTRIBUTES

COMBOBOX dbs = FORMONLY.dbserver, NOT NULL, NOENTRY,
  ITEMS = (
    ("pgs","PostgreSQL"),
    ("ora","Oracle Database"),
    ("mys","Oracle MySQL"),
    ("snc","SQL Server"),
    ("ifx","Informix"),
    ("mdb","MariaDB")
  );
EDIT src = FORMONLY.dbsource, NOENTRY, STRETCH=X, SCROLL;

COMBOBOX pro = FORMONLY.ai_provider, NOT NULL,
  ITEMS = (
    ("openai","OpenAI/GPT"),
    ("mistral","Mistral/Mistral"),
    ("gemini","Google/Gemini"),
    ("anthropic","Anthropic/Claude")
  ),
  COMMENT="WARNING: Changing AI provider resets generated vectors!";
EDIT mod = FORMONLY.ai_model, STRETCH=X, SCROLL;
COMBOBOX dim = FORMONLY.vector_dimension, NOT NULL,
  ITEMS = (128, 384, 768, 1024, 1536);
EDIT csm = FORMONLY.max_cosine_similarity, NOT NULL,
  COMMENT="Max cosine distance must be adapted to the chosen embedding model";

BUTTON b1: init_sql_table,
   TEXT="1. Init SQL table";
BUTTON b2: fill_item_list,
   TEXT="2. Load item list";
BUTTON b3: compute_vector_embeddings,
   TEXT="3. Compute embeddings";

LABEL id = FORMONLY.il_id;
LABEL sn = FORMONLY.il_short_name;
LABEL ca = FORMONLY.il_category;
TEXTEDIT de = FORMONLY.il_description;
TEXTEDIT ve = FORMONLY.il_vector, COLOR=RED;

TEXTEDIT smg = FORMONLY.system_message, STRETCH=BOTH,
  PLACEHOLDER="Enter the system message for the LLM here";

TEXTEDIT qry = FORMONLY.search_context, STRETCH=BOTH,
  PLACEHOLDER="Enter a search context for items here";
BUTTON csv: search_vector, TEXT="Compute context vector", IMAGE="fa-cogs",
  COMMENT="Generate the vector from the search context";
BUTTON fma: find_match, TEXT="Find matching rows in local DB", IMAGE="fa-database",
  COMMENT="Find similar matching items description in local SQL database";
TEXTEDIT qrv = FORMONLY.search_vector, COLOR=RED, STRETCH=BOTH;
TEXTEDIT amg = FORMONLY.context_data, STRETCH=BOTH;

TEXTEDIT uq1 = FORMONLY.user_question_1, STRETCH=BOTH,
  PLACEHOLDER="Enter a user prompt for the LLM here";
BUTTON q1: ask_llm_1, TEXT="Send user question to LLM", IMAGE="fa-send",
  COMMENT="Send request to LLM";
TEXTEDIT rs1 = FORMONLY.llm_response_1, STRETCH=BOTH;

TEXTEDIT uq2 = FORMONLY.user_question_2, STRETCH=BOTH,
  PLACEHOLDER="Enter a user prompt for the LLM here";
BUTTON q2: ask_llm_2, TEXT="Send user question to LLM", IMAGE="fa-send",
  COMMENT="Send request to LLM";
TEXTEDIT rs2 = FORMONLY.llm_response_2, STRETCH=BOTH;

END

INSTRUCTIONS
SCREEN RECORD sr_item_list(
   FORMONLY.il_id,
   FORMONLY.il_short_name,
   FORMONLY.il_category,
   FORMONLY.il_description,
   FORMONLY.il_vector
);
END
